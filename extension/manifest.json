{
  "manifest_version": 3,
  "name": "Ecosystem URL Capture",
  "version": "2.0.0",
  "description": "Capture the current tab's URL into one or more shared Supabase collections.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://*.supabase.co/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
